# Copy to .env and adjust values.
DATABASE_URL="file:./db/custom.db"

# Session signing for admin (generate a long random string in production)
AUTH_SECRET=
# NEXTAUTH_SECRET=

# --- Firebase (Firestore) for serverless hosts (Vercel, Netlify) ---
# Paste the entire JSON of a service account (Project settings → Service accounts).
# When set, the app runtime reads/writes platform data from Firestore/Firebase Storage.
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
#
# Optional: override the default bucket (${project_id}.appspot.com)
# FIREBASE_STORAGE_BUCKET=ciar-real.appspot.com
#
# Optional: collection id (default: properties)
# FIRESTORE_PROPERTIES_COLLECTION=properties
#
# Optional: max documents loaded per list request before in-memory filters (default 800)
# FIRESTORE_QUERY_MAX_DOCS=800
#
# Optional: top up Firestore to this many listings per country during db:migrate-firestore (default 30)
# FIRESTORE_PROPERTIES_PER_COUNTRY_TARGET=30
