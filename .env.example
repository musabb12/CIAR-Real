# Copy to .env and adjust values.
DATABASE_URL="file:./db/custom.db"

# Session signing for admin (generate a long random string in production)
AUTH_SECRET=
# NEXTAUTH_SECRET=

# --- Firebase (Firestore) for serverless hosts (e.g. Netlify) ---
# Paste the entire JSON of a service account (Project settings → Service accounts).
# When set, GET /api/properties and GET /api/properties/[id] read from Firestore first.
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
#
# Optional: collection id (default: properties)
# FIRESTORE_PROPERTIES_COLLECTION=properties
#
# Optional: max documents loaded per list request before in-memory filters (default 800)
# FIRESTORE_QUERY_MAX_DOCS=800
